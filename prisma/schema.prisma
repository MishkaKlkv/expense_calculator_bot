datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Currency {
  RUB
  USD
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum FamilyRole {
  OWNER
  MEMBER
}

enum CategoryType {
  EXPENSE
  INCOME
}

enum AccountKind {
  AVAILABLE
  SAVINGS
}

enum TrackedDaySource {
  TRANSACTION
  MANUAL_DONE
}

enum DialogStateType {
  IDLE
  ADD_EXPENSE_WAITING_FOR_CATEGORY
  ADD_EXPENSE_WAITING_FOR_DETAILS
  ADD_EXPENSE_WAITING_FOR_CASHBACK
  ADD_INCOME_WAITING_FOR_CATEGORY
  ADD_INCOME_WAITING_FOR_DETAILS
  EDIT_TRANSACTION_WAITING_FOR_FIELD
  DELETE_TRANSACTION_CONFIRMATION
}

model TelegramUser {
  id              String                @id @default(cuid())
  telegramUserId  BigInt                @unique @map("telegram_user_id")
  username        String?
  firstName       String?               @map("first_name")
  lastName        String?               @map("last_name")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  expenses        Expense[]
  dialogState     DialogState?
  dailyReminder   DailyReminder?
  weeklyReport    WeeklyReportDelivery?
  plannedPayments PlannedPayment[]
  accounts        Account[]
  gamification    UserGamification?
  trackedDays     TrackedDay[]
  achievements    UserAchievement[]
  categories      UserCategory[]
  familyMembers   FamilyMember[]
  createdFamilies FamilyAccount[]       @relation("CreatedFamilies")

  @@map("telegram_users")
}

model UserGamification {
  id              String       @id @default(cuid())
  userId          String       @unique @map("user_id")
  xp              Int          @default(0)
  currentStreak   Int          @default(0) @map("current_streak")
  bestStreak      Int          @default(0) @map("best_streak")
  lastTrackedDate String?      @map("last_tracked_date")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  user            TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_gamification")
}

model TrackedDay {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  dateKey   String           @map("date_key")
  source    TrackedDaySource
  xpAwarded Int              @default(0) @map("xp_awarded")
  createdAt DateTime         @default(now()) @map("created_at")
  user      TelegramUser     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, dateKey])
  @@map("tracked_days")
}

model UserAchievement {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  code       String
  unlockedAt DateTime     @default(now()) @map("unlocked_at")
  user       TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
  @@map("user_achievements")
}

model Account {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  name      String
  kind      AccountKind  @default(AVAILABLE)
  balance   Decimal      @default(0) @db.Decimal(12, 2)
  currency  Currency     @default(RUB)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  user      TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, kind])
  @@map("accounts")
}

model PlannedPayment {
  id                    String       @id @default(cuid())
  userId                String       @map("user_id")
  category              String
  description           String
  amount                Decimal      @db.Decimal(12, 2)
  currency              Currency
  dayOfMonth            Int          @map("day_of_month")
  enabled               Boolean      @default(true)
  reminderEnabled       Boolean      @default(false) @map("reminder_enabled")
  reminderTimeOfDay     String       @default("10:00") @map("reminder_time_of_day")
  lastReminderSentMonth String?      @map("last_reminder_sent_month")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  user                  TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([reminderEnabled, dayOfMonth])
  @@map("planned_payments")
}

model WeeklyReportDelivery {
  id           String       @id @default(cuid())
  userId       String       @unique @map("user_id")
  lastSentWeek String?      @map("last_sent_week")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  user         TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weekly_report_deliveries")
}

model UserCategory {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  type      CategoryType
  name      String
  sortOrder Int          @default(1000) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  user      TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, name])
  @@index([userId, type])
  @@map("user_categories")
}

model FamilyAccount {
  id              String         @id @default(cuid())
  name            String
  inviteCode      String         @unique @map("invite_code")
  createdByUserId String         @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdBy       TelegramUser   @relation("CreatedFamilies", fields: [createdByUserId], references: [id], onDelete: Cascade)
  members         FamilyMember[]

  @@map("family_accounts")
}

model FamilyMember {
  id              String        @id @default(cuid())
  familyAccountId String        @map("family_account_id")
  userId          String        @unique @map("user_id")
  role            FamilyRole    @default(MEMBER)
  joinedAt        DateTime      @default(now()) @map("joined_at")
  familyAccount   FamilyAccount @relation(fields: [familyAccountId], references: [id], onDelete: Cascade)
  user            TelegramUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyAccountId])
  @@map("family_members")
}

model Expense {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  telegramUserId BigInt          @map("telegram_user_id")
  type           TransactionType @default(EXPENSE)
  category       String
  description    String
  amount         Decimal         @db.Decimal(12, 2)
  cashback       Decimal         @default(0) @db.Decimal(12, 2)
  currency       Currency
  expenseDate    DateTime        @default(now()) @map("expense_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           TelegramUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telegramUserId, expenseDate])
  @@index([userId, type, expenseDate])
  @@map("expenses")
}

model DialogState {
  id        String          @id @default(cuid())
  userId    String          @unique @map("user_id")
  state     DialogStateType @default(IDLE)
  payload   Json?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  user      TelegramUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dialog_states")
}

model DailyReminder {
  id           String       @id @default(cuid())
  userId       String       @unique @map("user_id")
  timeOfDay    String       @map("time_of_day")
  timezone     String       @default("Europe/Moscow")
  enabled      Boolean      @default(true)
  lastSentDate String?      @map("last_sent_date")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  user         TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enabled, timeOfDay])
  @@map("daily_reminders")
}

model BotEvent {
  id             String   @id @default(cuid())
  telegramUserId BigInt?  @map("telegram_user_id")
  updateType     String   @map("update_type")
  eventType      String   @map("event_type")
  eventName      String?  @map("event_name")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([telegramUserId, createdAt])
  @@index([eventType, eventName, createdAt])
  @@map("bot_events")
}
